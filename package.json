{
	"name": "boilerplate",
	"description": "Boilerplate: Typescript, Webpack, Isomorphic React, Sass, Handlebars, Material UI",
	"version": "3.3.0",
	"main": "server.ts",
	"author": "Fun Maker",
	"repository": "https://github.com/funmaker/webapp-boilerplate",
	"engines": {
		"node": ">=14.0.0",
		"npm": ">=7.0.0"
	},
	"scripts": {
		"start": "rm -rf build && webpack --config webpack/server.dev.ts",
		"start:prod": "cd dist && npm start",
		"build:prod": "mkdir -p dist && npm-run-all build:prod-*",
		"build:prod-server": "webpack --config webpack/server.prod.ts",
		"build:prod-client": "webpack --config webpack/client.prod.ts",
		"build:prod-static": "cp -rL static dist/",
		"build:prod-package": "babel-node webpack/package.ts",
		"lint": "eslint --ext .js --ext .jsx --ext .ts --ext .tsx --max-warnings 0",
		"lint-fix": "eslint --ext .js --ext .jsx --ext .ts --ext .tsx --fix"
	},
	"dependencies": {
		"@emotion/styled": "^11.14.1",
		"@mui/material": "^7.3.7",
		"@mui/styled-engine": "^7.3.7",
		"axios": "^1.13.5",
		"babel-plugin-react-compiler": "^1.0.0",
		"body-parser": "^2.2.2",
		"chalk": "^5.6.2",
		"compression": "^1.8.1",
		"connect-pg-simple": "^10.0.0",
		"cookie-parser": "^1.4.7",
		"core-js": "^3.47.0",
		"csurf": "^1.11.0",
		"detect-node": "^2.1.0",
		"express": "^5.2.1",
		"express-handlebars": "^8.0.4",
		"express-session": "^1.18.2",
		"lorem-ipsum": "^2.0.8",
		"morgan": "^1.10.1",
		"pg": "^8.17.1",
		"prop-types": "^15.8.1",
		"qs": "^6.14.2",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-toastify": "^11.0.5",
		"resize-observer-polyfill": "^1.5.1",
		"source-map-support": "^0.5.21",
		"sql-template-strings": "^2.2.2",
		"use-debounce": "^10.1.0",
		"wouter": "^3.9.0"
	},
	"devDependencies": {
		"@babel/core": "^7.28.6",
		"@babel/node": "^7.28.6",
		"@babel/preset-env": "^7.28.6",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@babel/register": "^7.28.6",
		"@emotion/babel-plugin": "^11.13.5",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.2",
		"@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
		"@stylistic/eslint-plugin": "^5.7.0",
		"@types/body-parser": "^1.19.6",
		"@types/compression": "^1.8.1",
		"@types/connect-pg-simple": "^7.0.3",
		"@types/cookie-parser": "^1.4.10",
		"@types/csurf": "^1.11.5",
		"@types/detect-node": "^2.0.2",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.18.2",
		"@types/morgan": "^1.9.10",
		"@types/node": "^25.0.9",
		"@types/pg": "^8.16.0",
		"@types/react": "^19.2.9",
		"@types/react-dom": "^19.2.3",
		"@types/webpack-env": "^1.18.8",
		"@types/webpack-hot-middleware": "^2.25.12",
		"@types/webpack-node-externals": "^3.0.4",
		"@typescript-eslint/eslint-plugin": "^8.53.1",
		"@typescript-eslint/parser": "^8.53.1",
		"babel-loader": "^10.0.0",
		"css-loader": "^7.1.2",
		"eslint": "^9.39.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-indent-empty-lines": "^2.0.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.0.0",
		"handlebars": "^4.7.9",
		"handlebars-loader": "^1.7.3",
		"ignore-loader": "^0.1.2",
		"jiti": "^2.6.1",
		"mini-css-extract-plugin": "^2.10.0",
		"npm-run-all": "^4.1.5",
		"raw-loader": "^4.0.2",
		"react-refresh": "^0.18.0",
		"run-script-webpack-plugin": "=0.2.2",
		"style-loader": "^4.0.0",
		"typescript": "^5.9.3",
		"webpack": "^5.104.1",
		"webpack-cli": "^6.0.1",
